@model GDG_DashBoard.DAL.Models.CommunityGroup

@{
    ViewData["Title"] = Model.Name;
    Layout = "_AdminLayout";
}

<div class="max-w-4xl mx-auto space-y-8 px-4 py-8 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div class="flex items-center gap-4">
            <a asp-controller="Member" asp-action="MyProfile" class="w-10 h-10 rounded-xl bg-surface-container-high flex items-center justify-center hover:bg-surface-container-highest transition-colors">
                <span class="material-symbols-outlined text-on-surface/70">arrow_back</span>
            </a>
            <div>
                <h1 class="text-3xl font-bold tracking-tight font-headline text-on-surface">@Model.Name</h1>
                <p class="text-sm text-on-surface/50 font-medium mt-1">Community Cohort</p>
            </div>
        </div>

        @if (User.IsInRole("Admin") || User.IsInRole("Organizer") || User.IsInRole("Mentor"))
        {
            <div class="flex items-center gap-3">
                <a asp-action="GroupViolations" asp-route-id="@Model.Id" class="px-5 py-2.5 bg-error/10 text-error hover:bg-error hover:text-white hover:shadow-md hover:shadow-error/25 hover:-translate-y-0.5 rounded-xl text-sm font-bold tracking-wide transition-all inline-flex items-center gap-2 border border-error/20">
                    <span class="material-symbols-outlined text-[18px]">gavel</span> Security Alerts
                </a>
            </div>
        }
    </div>

    <!-- Group Info Card -->
    <div class="bg-surface-container-lowest rounded-3xl p-8 border border-outline-variant/10 shadow-sm">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center">
                <span class="material-symbols-outlined text-primary text-2xl">groups</span>
            </div>
            <div>
                <h2 class="text-xl font-bold font-headline">@Model.Name</h2>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-sm text-on-surface/60 mt-1">@Model.Description</p>
                }
            </div>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-6">
            <div class="p-4 bg-surface-container-low rounded-2xl text-center">
                <span class="text-2xl font-black text-primary">@(Model.GroupMembers?.Count ?? 0)</span>
                <p class="text-xs font-bold text-on-surface/50 mt-1 uppercase tracking-wider">Members</p>
            </div>
            <div class="p-4 bg-surface-container-low rounded-2xl text-center">
                <span class="text-2xl font-black text-secondary">@(Model.Roadmap != null ? "1" : "0")</span>
                <p class="text-xs font-bold text-on-surface/50 mt-1 uppercase tracking-wider">Roadmap</p>
            </div>
        </div>
    </div>

    <!-- Assigned Roadmap -->
    @if (Model.Roadmap != null)
    {
        <div class="bg-surface-container-lowest rounded-3xl p-8 border border-outline-variant/10 shadow-sm">
            <div class="flex items-center gap-3 mb-4">
                <span class="material-symbols-outlined text-2xl text-secondary">route</span>
                <h3 class="text-xl font-bold font-headline">Assigned Roadmap</h3>
            </div>
            <div class="p-4 border border-outline-variant/20 rounded-2xl bg-surface-container-low">
                <h4 class="font-bold text-on-surface text-lg">@Model.Roadmap.Title</h4>
                @if (!string.IsNullOrEmpty(Model.Roadmap.Description))
                {
                    <p class="text-sm text-on-surface/60 mt-2">@Model.Roadmap.Description</p>
                }
                <div class="flex items-center gap-4 mt-3 text-xs font-bold text-on-surface/50 mb-5">
                    <span>📊 @Model.Roadmap.Level</span>
                    <span>⏱️ ~@Model.Roadmap.EstimatedTotalHours hrs</span>
                </div>
                <!-- Direct entry point for learning -->
                @if (ViewBag.IsEnrolled == true)
                {
                    <a asp-controller="Member" asp-action="RoadmapDetails" asp-route-id="@Model.Roadmap.Id" 
                       class="block w-full text-center px-6 py-4 bg-primary text-white rounded-xl text-lg font-black shadow-lg shadow-primary/25 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary/30 transition-all">
                        Continue Learning 🚀
                    </a>
                }
                else
                {
                    <form asp-controller="Member" asp-action="EnrollInRoadmap" asp-route-id="@Model.Roadmap.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="w-full text-center px-6 py-4 bg-on-surface text-surface rounded-xl text-lg font-black shadow-lg hover:-translate-y-1 hover:shadow-xl transition-all">
                            Enroll in Track
                        </button>
                    </form>
                }
            </div>
        </div>
    }

    <!-- Fellow Members -->
    @if (Model.GroupMembers?.Any() == true)
    {
        <div class="bg-surface-container-lowest rounded-3xl p-8 border border-outline-variant/10 shadow-sm">
            <div class="flex items-center gap-3 mb-4">
                <span class="material-symbols-outlined text-2xl text-tertiary">diversity_3</span>
                <h3 class="text-xl font-bold font-headline">Fellow Members</h3>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                @foreach (var gm in Model.GroupMembers)
                {
                    <div class="flex items-center gap-3 p-3 bg-surface-container-low rounded-xl">
                        <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center">
                            <span class="text-sm font-black text-primary">@(gm.Member?.UserName?.FirstOrDefault() ?? '?')</span>
                        </div>
                        <span class="text-sm font-medium text-on-surface">@(gm.Member?.UserName ?? gm.Member?.Email ?? "Unknown")</span>
                    </div>
                }
            </div>
        </div>
    }
</div>
