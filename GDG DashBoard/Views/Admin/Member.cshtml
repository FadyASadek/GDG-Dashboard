@model GDG_DashBoard.ViewModels.Admin.MemberDetailViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Member Profile";
    ViewData["PageTitle"] = Model.Member.FullName;
    var member = Model.Member;
}

<div class="max-w-5xl mx-auto space-y-12">

    <!-- Back nav -->
    <nav class="flex text-[11px] font-bold tracking-wider text-primary uppercase">
        <ol class="flex items-center space-x-2">
            <li><a asp-controller="Admin" asp-action="Index" class="hover:underline">Dashboard</a></li>
            <li class="flex items-center space-x-2">
                <span class="material-symbols-outlined text-[12px]">chevron_right</span>
                <span>@member.FullName</span>
            </li>
        </ol>
    </nav>

    <!-- ══ PROFILE HEADER ░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ -->
    <section class="relative bg-surface-container-low rounded-3xl p-10 overflow-hidden border border-outline-variant/10">
        <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary/5 to-transparent pointer-events-none"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-start md:items-center gap-8">

            <!-- Avatar -->
            <div class="relative">
                <div class="w-32 h-32 rounded-3xl overflow-hidden shadow-2xl ring-4 ring-white bg-primary/10 flex items-center justify-center">
                    <span class="text-6xl font-black font-headline text-primary/50">@member.FullName.Substring(0, 1).ToUpper()</span>
                </div>
                @if (member.IsVerified)
                {
                    <div class="absolute -bottom-2 -right-2 bg-secondary text-white p-2 rounded-xl shadow-lg flex items-center justify-center">
                        <span class="material-symbols-outlined text-sm" style="font-variation-settings:'FILL' 1;">verified</span>
                    </div>
                }
            </div>

            <!-- Basic Info -->
            <div class="flex-1">
                <span class="text-xs font-bold tracking-[0.15em] text-primary uppercase font-headline">
                    @member.Role @(member.IsVerified ? "• Verified" : "")
                </span>
                <h1 class="text-4xl font-extrabold tracking-tighter text-on-surface font-headline mt-1">@member.FullName</h1>
                <div class="flex flex-wrap items-center gap-4 mt-2 text-on-surface/60 font-medium text-sm">
                    <span class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-lg">mail</span>
                        @member.Email
                    </span>
                    @if (!string.IsNullOrEmpty(member.Location))
                    {
                        <span class="w-1.5 h-1.5 rounded-full bg-outline-variant/50"></span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-lg">location_on</span>
                            @member.Location
                        </span>
                    }
                    @if (!string.IsNullOrEmpty(member.Season))
                    {
                        <span class="w-1.5 h-1.5 rounded-full bg-outline-variant/50"></span>
                        <span class="flex items-center gap-1">
                            <span class="material-symbols-outlined text-lg">calendar_today</span>
                            @member.Season
                        </span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(member.ProfessionalSummary))
                {
                    <div class="mt-6 max-w-2xl">
                        <p class="text-base text-on-surface/70 leading-relaxed">
                            @member.ProfessionalSummary
                        </p>
                    </div>
                }

                <!-- Social Links -->
                <div class="mt-5 flex gap-3">
                    @if (!string.IsNullOrEmpty(member.GitHubUrl))
                    {
                        <a href="@member.GitHubUrl" target="_blank" rel="noopener"
                           class="px-4 py-2 bg-on-surface/5 hover:bg-on-surface/10 rounded-lg text-xs font-bold flex items-center gap-2 transition-colors">
                            <span class="material-symbols-outlined text-sm">code</span>
                            GitHub
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(member.LinkedInUrl))
                    {
                        <a href="@member.LinkedInUrl" target="_blank" rel="noopener"
                           class="px-4 py-2 bg-primary/5 hover:bg-primary/10 rounded-lg text-xs font-bold text-primary flex items-center gap-2 transition-colors">
                            <span class="material-symbols-outlined text-sm">person</span>
                            LinkedIn
                        </a>
                    }
                    <a asp-controller="Admin" asp-action="Roadmap" asp-route-id="@member.UserId"
                       class="px-4 py-2 bg-secondary/5 hover:bg-secondary/10 rounded-lg text-xs font-bold text-secondary flex items-center gap-2 transition-colors">
                        <span class="material-symbols-outlined text-sm">map</span>
                        View Roadmap
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ SKILLS GRID ══════════════════════════════════════════════════════════ -->
    @if (member.TechnicalSkills.Any() || member.SoftSkills.Any())
    {
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
            @if (member.TechnicalSkills.Any())
            {
                <div class="bg-surface-container-lowest p-8 rounded-3xl shadow-sm border-t-4 border-primary">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                            <span class="material-symbols-outlined">code</span>
                        </div>
                        <h3 class="text-xl font-bold font-headline">Technical Stack</h3>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var skill in member.TechnicalSkills)
                        {
                            <span class="px-4 py-2 rounded-full bg-primary text-white text-sm font-semibold tracking-wide shadow-sm hover:scale-105 transition-transform cursor-default">
                                @skill.Name
                            </span>
                        }
                    </div>
                </div>
            }
            @if (member.SoftSkills.Any())
            {
                <div class="bg-surface-container-lowest p-8 rounded-3xl shadow-sm border-t-4 border-secondary">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary">
                            <span class="material-symbols-outlined">groups</span>
                        </div>
                        <h3 class="text-xl font-bold font-headline">Soft Skills</h3>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        @foreach (var skill in member.SoftSkills)
                        {
                            <span class="px-4 py-2 rounded-full bg-secondary text-white text-sm font-semibold tracking-wide shadow-sm hover:scale-105 transition-transform cursor-default">
                                @skill.Name
                            </span>
                        }
                    </div>
                </div>
            }
        </section>
    }

    <!-- ══ EXPERIENCE ══════════════════════════════════════════════════════════ -->
    @if (member.Experiences.Any())
    {
        <section class="space-y-8">
            <div class="flex items-center justify-between">
                <h2 class="text-3xl font-bold tracking-tight font-headline">Work Experience</h2>
                <div class="h-px flex-1 mx-8 bg-surface-container-highest"></div>
            </div>
            <div class="relative space-y-8 before:content-[''] before:absolute before:left-[21px] before:top-4 before:bottom-4 before:w-[2px] before:bg-surface-container-highest">
                @foreach (var exp in member.Experiences)
                {
                    <div class="relative flex gap-8 group">
                        <div class="z-10 flex-shrink-0 w-11 h-11 rounded-full bg-surface-container-lowest border-4 border-surface flex items-center justify-center shadow-md group-hover:border-primary/20 transition-colors">
                            <span class="material-symbols-outlined text-sm text-primary/60">work</span>
                        </div>
                        <div class="flex-1 pb-4">
                            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-1 mb-2">
                                <h4 class="text-xl font-bold text-on-surface font-headline">@exp.Title</h4>
                                <span class="text-sm font-medium text-on-surface/40">
                                    @exp.StartDate.ToString("MMM yyyy") — @(exp.EndDate.HasValue ? exp.EndDate.Value.ToString("MMM yyyy") : "Present")
                                </span>
                            </div>
                            <p class="text-primary font-bold mb-3 tracking-wide text-sm uppercase">@exp.Company</p>
                            @if (!string.IsNullOrEmpty(exp.Description))
                            {
                                <p class="text-on-surface/70 leading-relaxed max-w-3xl">@exp.Description</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- ══ PROJECTS ════════════════════════════════════════════════════════════ -->
    @if (member.Projects.Any())
    {
        <section class="space-y-8 pb-16">
            <div class="flex items-center justify-between">
                <h2 class="text-3xl font-bold tracking-tight font-headline">Projects</h2>
                <div class="h-px flex-1 mx-8 bg-surface-container-highest"></div>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @{
                    string[] borderColors = { "border-gdg-yellow", "border-gdg-green", "border-gdg-red", "border-primary" };
                }
                @for (int i = 0; i < member.Projects.Count; i++)
                {
                    var project = member.Projects[i];
                    var bc = borderColors[i % borderColors.Length];
                    <div class="group bg-surface-container-lowest rounded-3xl overflow-hidden shadow-sm border-t-4 @bc hover:shadow-xl transition-all flex flex-col">
                        <div class="p-8 flex-1 flex flex-col">
                            <div class="flex justify-between items-start mb-4">
                                <h3 class="text-xl font-bold font-headline">@project.Name</h3>
                                @if (!string.IsNullOrEmpty(project.Url))
                                {
                                    <a href="@project.Url" target="_blank" rel="noopener"
                                       class="w-10 h-10 rounded-full bg-surface-container-low flex items-center justify-center hover:bg-primary hover:text-white transition-colors">
                                        <span class="material-symbols-outlined text-xl">open_in_new</span>
                                    </a>
                                }
                                else
                                {
                                    <span class="px-3 py-1 rounded-full bg-surface-container-highest text-on-surface/60 text-[10px] font-bold tracking-wider uppercase">Private</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(project.Description))
                            {
                                <p class="text-on-surface/60 leading-relaxed flex-1">@project.Description</p>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
    }

    <!-- Empty state -->
    @if (!member.TechnicalSkills.Any() && !member.Experiences.Any() && !member.Projects.Any())
    {
        <div class="text-center py-24 text-on-surface/30">
            <span class="material-symbols-outlined text-6xl mb-4 block">person_outline</span>
            <p class="font-bold font-headline text-xl mb-2">Profile Not Yet Filled</p>
            <p class="text-sm">This member hasn't completed their profile yet.</p>
        </div>
    }

</div>
